pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/
nbactions.xml
nb-configuration.xml

# VSCode
.vscode/

# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/

# Logs
*.log

# Sistema Operativo
.DS_Store
Thumbs.db
desktop.ini

# Credenciales locales
src/main/resources/database.properties

# Datos de prueba (archivos pesados generados)
seed_data.sql

