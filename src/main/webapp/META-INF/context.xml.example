<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <!-- 
        COPIA ESTE ARCHIVO, QUÍTALE EL ".example" Y NÓMBRALO "context.xml".
        Luego pon tus credenciales reales en username, password y url.
        (El context.xml real será ignorado por Git).
    -->
    <Resource name="jdbc/LibraryDB" 
              auth="Container" 
              type="javax.sql.DataSource"
              maxTotal="20" 
              maxIdle="10" 
              maxWaitMillis="-1"
              username="root" 
              password="PON_TU_PASSWORD_AQUI" 
              driverClassName="com.mysql.cj.jdbc.Driver"
              url="jdbc:mysql://localhost:3306/PON_TU_BASE_DE_DATOS_AQUI?useSSL=false&amp;serverTimezone=UTC"/>
</Context>
